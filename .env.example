# Copy to .env.local for local dev (never commit .env.local).
# On Vercel: Project → Settings → Environment Variables
# All of these are NEXT_PUBLIC_* because auth/push runs in the browser.

# GitHub repo the GitHub App should push to
NEXT_PUBLIC_GITHUB_OWNER=Achermanxuyi
NEXT_PUBLIC_GITHUB_REPO=portfolio-plus
NEXT_PUBLIC_GITHUB_BRANCH=main

# From GitHub → Settings → Developer settings → GitHub Apps → your app → App ID
NEXT_PUBLIC_GITHUB_APP_ID=2568144

# Optional: random string for encrypting cached PEM in sessionStorage.
# This is NOT a real secret (it ships in the public JS bundle).
# Generate with: openssl rand -base64 32
# NEXT_PUBLIC_GITHUB_ENCRYPT_KEY=

# NEVER put the GitHub App .pem private key in env vars.
# Import it in the browser when you click "Import key" while editing.
